{
    "name": "socialiteproviders/telegram-openid",
    "description": "Telegram OpenID Connect OAuth2 provider for Laravel Socialite.",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "socialite",
        "socialiteproviders",
        "telegram",
        "openid",
        "oauth"
    ],
    "authors": [
        {
            "name": "SocialiteProviders Contributors"
        }
    ],
    "require": {
        "php": "^8.1",
        "firebase/php-jwt": "^7.1",
        "laravel/socialite": "^5.24.1",
        "socialiteproviders/manager": "^4.8"
    },
    "require-dev": {
        "orchestra/testbench": "^8.0|^9.0|^10.0",
        "pestphp/pest": "^2.34|^3.0",
        "pestphp/pest-plugin-laravel": "^2.4|^3.0"
    },
    "autoload": {
        "psr-4": {
            "SocialiteProviders\\TelegramOpenId\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SocialiteProviders\\TelegramOpenId\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "pest",
        "test:coverage": "pest --coverage"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
